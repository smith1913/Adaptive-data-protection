// PDE decisions for unknown person role — field-by-field
function runPDE_Unknown(mlResult, ruleResult, tiResult, context) {
  const decisions = {};
  FIELD_DEFS.forEach(f => {
    let method, reason;
    switch(f.key){
      case 'type':   method='visible';        reason='public:account_category'; break;
      case 'branch': method='visible';        reason='public:branch_city'; break;
      case 'name':   method='partial_reveal'; reason='unauth:name_initial_only'; break;
      case 'ifsc':   method='partial_reveal'; reason='unauth:bank_code_only'; break;
      case 'accno':  method='masking';        reason='unauth:account_mask'; break;
      case 'cscore': method='masking';        reason='unauth:financial_mask'; break;
      case 'balance':method='full_redaction'; reason='unauth:balance_hidden'; break;
      case 'txn':    method='full_redaction'; reason='unauth:txn_hidden'; break;
      case 'pan':    method='full_redaction'; reason='unauth:gov_id_hidden'; break;
      case 'aadhaar':method='full_redaction'; reason='unauth:gov_id_hidden'; break;
      case 'phone':  method='full_redaction'; reason='unauth:contact_hidden'; break;
      case 'email':  method='full_redaction'; reason='unauth:contact_hidden'; break;
      case 'addr':   method='full_redaction'; reason='unauth:contact_hidden'; break;
      case 'dob':    method='anonymisation';  reason='unauth:quasi_id_anon'; break;
      default:       method='masking';        reason='unauth:default_mask';
    }
    const techniqueMap={visible:'plaintext',masking:'partial_masking',partial_reveal:'first_char_only',full_redaction:'suppression',anonymisation:'k-anon+generalisation'};
    decisions[f.key]={method, reason, technique:techniqueMap[method]||'unknown'};
  });
  return decisions;
}

function applyUnknownMethod(v, method, fieldKey) {
  if(!v||v==='—') return '—';
  const s = String(v).trim();
  switch(method){
    case 'visible':        return s;
    case 'partial_reveal': return s[0] + '•'.repeat(Math.max(0, s.length - 1));
    case 'masking':        return '•••• •••• '+s.slice(-3);
    case 'full_redaction': return '[PROTECTED]';
    case 'anonymisation':  return '[ANON:k=5]';
    default:               return '[MASKED]';
  }
}

function renderUnknownFields(record, pdeDecisions) {
  const fl = document.getElementById('unk-fl');
  fl.innerHTML = '';
  FIELD_DEFS.forEach(f => {
    const raw  = record[f.key] || '—';
    const dec  = pdeDecisions[f.key] || {method:'full_redaction',reason:'no_decision'};
    const pv   = applyUnknownMethod(raw, dec.method, f.key);
    const ms   = MSTYLE[dec.method] || MSTYLE.full_redaction;
    const isBlurred  = ['full_redaction','anonymisation','masking'].includes(dec.method);
    const isPartial  = dec.method === 'partial_reveal';
    const isVisible  = dec.method === 'visible';

    const valStyle = isVisible ? 'color:var(--txt)' : isPartial ? 'color:var(--amber2)' : 'color:rgba(196,122,10,0.3);filter:blur(3px);user-select:none;';
    const rowOpacity = isVisible ? '1' : isPartial ? '0.85' : '0.55';
    const lockIcon = isVisible ? '' : isPartial ? '〜' : '🔒';

    const d = document.createElement('div');
    d.className = 'frow';
    d.style.opacity = rowOpacity;
    d.innerHTML = `
      <span class="frow-icon" style="${isBlurred?'opacity:.3':''}">${f.icon}</span>
      <span class="frow-lbl" style="${isBlurred?'color:rgba(196,122,10,0.3)':isPartial?'color:var(--amber2)':''}">${f.label}</span>
      <span class="frow-val" style="${valStyle}">${pv}</span>
      <span style="font-size:9px;margin-right:2px;">${lockIcon}</span>
      <span class="sdot" style="background:${ms.c}66"></span>
      <span class="mtag" style="background:${ms.bg};color:${ms.c};border:1px solid ${ms.br}">${ms.lbl==='Visible'?'Open':ms.lbl}</span>
    `;
    fl.appendChild(d);
  });
}

