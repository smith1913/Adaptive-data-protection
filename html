<script>
'use strict';

// ═══════════════════════════════════════════════════════
// 1. IndexedDB
// ═══════════════════════════════════════════════════════
const DB = { name:'SecureBankADPE5', ver:1, store:'customers' };
let db = null;

function openDB(){
  return new Promise((res,rej)=>{
    const r = indexedDB.open(DB.name, DB.ver);
    r.onupgradeneeded = e => {
      const d = e.target.result;
      if(!d.objectStoreNames.contains(DB.store)){
        const os = d.createObjectStore(DB.store,{keyPath:'id',autoIncrement:true});
        os.createIndex('ts','ts',{unique:false});
      }
    };
    r.onsuccess = e => { db = e.target.result; res(db); };
    r.onerror   = e => rej(e);
  });
}
function dbPut(rec){ return new Promise((res,rej)=>{ const r=db.transaction(DB.store,'readwrite').objectStore(DB.store).add(rec); r.onsuccess=()=>res(r.result); r.onerror=e=>rej(e); }); }
function dbAll(){ return new Promise((res,rej)=>{ const r=db.transaction(DB.store,'readonly').objectStore(DB.store).getAll(); r.onsuccess=()=>res(r.result); r.onerror=e=>rej(e); }); }

// ═══════════════════════════════════════════════════════
// 2. CONTEXT AWARENESS ENGINE
// ═══════════════════════════════════════════════════════
function buildContext(role, formData){
  const now = new Date();
  const hour = now.getHours();
  const dayOfWeek = now.getDay(); // 0=Sun

  const timeCtx = hour>=9&&hour<18 ? 'business_hours' : hour>=18&&hour<22 ? 'evening' : 'off_hours';
  const dayCtx  = dayOfWeek===0||dayOfWeek===6 ? 'weekend' : 'weekday';

  // Regulatory jurisdiction map
  const regMap = {
    india_rbi: { label:'India — RBI/DPDP', laws:['RBI 2006','DPDP Act 2023','Aadhaar Act 2016','IT Act 2000'], piiFields:['pan','aadhaar','phone','accno','balance'] },
    eu_gdpr:   { label:'European Union — GDPR', laws:['GDPR Art.25','PSD2','ePrivacy'], piiFields:['name','email','addr','dob','accno'] },
    us_pci:    { label:'United States — PCI-DSS', laws:['PCI-DSS v4.0','GLBA','CCPA'], piiFields:['accno','balance','pan','cscore'] },
    global:    { label:'Global Multi-jurisdiction', laws:['GDPR','PCI-DSS','RBI','ISO27001'], piiFields:['name','pan','aadhaar','accno','balance','email','phone'] },
  };
  const reg = regMap[formData?.ctxReg || 'india_rbi'];

  // Device fingerprint (simulated)
  const fingerprint = 'FP-' + (navigator.userAgent.length * 7 % 9999).toString(16).toUpperCase().padStart(4,'0');
  const ua = navigator.userAgent;
  const deviceType = /mobile/i.test(ua) ? 'mobile' : 'desktop';
  const browser = /chrome/i.test(ua) ? 'Chrome' : /firefox/i.test(ua) ? 'Firefox' : /safari/i.test(ua) ? 'Safari' : 'Unknown';

  return {
    role,
    timestamp: now.toISOString(),
    timeContext: timeCtx,
    dayContext: dayCtx,
    jurisdiction: reg,
    channel: formData?.ctxChannel || 'web_app',
    purpose: formData?.ctxPurpose || 'account_mgmt',
    sessionType: formData?.ctxSession || 'authenticated',
    deviceFingerprint: fingerprint,
    deviceType,
    browser,
    isWeekend: dayCtx === 'weekend',
    isOffHours: timeCtx !== 'business_hours',
    riskModifier: (timeCtx !== 'business_hours' ? 0.15 : 0) + (dayCtx === 'weekend' ? 0.1 : 0) + (role === 'third' ? 0.5 : 0),
  };
}

// ═══════════════════════════════════════════════════════
// 3. RULE-BASED CLASSIFICATION ENGINE
// ═══════════════════════════════════════════════════════
const RULES = [
  { id:'RB-001', name:'External role block', condition: ctx => ctx.role === 'third', action:'FULL_REDACT_ALL', severity:'CRITICAL', category:'access_control' },
  { id:'RB-002', name:'Off-hours sensitive access', condition:(ctx,ml)=>ctx.isOffHours&&ml.score>40, action:'ESCALATE_PROTECTION', severity:'HIGH', category:'temporal' },
  { id:'RB-003', name:'TOR/Darknet network', condition:(ctx,ml,ti)=>ml.signals?.loc==='tor', action:'BLOCK_AND_ALERT', severity:'CRITICAL', category:'network' },
  { id:'RB-004', name:'Blacklisted IP', condition:(ctx,ml,ti)=>ti.ipRep==='blacklisted', action:'FULL_REDACT_ALL', severity:'CRITICAL', category:'threat_intel' },
  { id:'RB-005', name:'Bulk data dump attempt', condition:(ctx,ml)=>ml.signals?.vol==='bulk', action:'MASK_CRITICAL_FIELDS', severity:'HIGH', category:'data_volume' },
  { id:'RB-006', name:'Rapid/bot-like access', condition:(ctx,ml)=>ml.signals?.vel==='rapid', action:'TOKENIZE_PII', severity:'HIGH', category:'velocity' },
  { id:'RB-007', name:'Third-party data purpose', condition:(ctx)=>ctx.purpose==='third_party', action:'ANONYMISE_ALL', severity:'HIGH', category:'purpose' },
  { id:'RB-008', name:'Analytics/reporting access', condition:(ctx)=>ctx.purpose==='analytics', action:'PSEUDONYMISE_DIRECT_ID', severity:'MEDIUM', category:'purpose' },
  { id:'RB-009', name:'Multi-failure login', condition:(ctx,ml)=>ml.signals?.logins>=3, action:'ENCRYPT_CRITICAL', severity:'MEDIUM', category:'authentication' },
  { id:'RB-010', name:'Extreme geo anomaly', condition:(ctx,ml)=>ml.signals?.geo==='extreme', action:'TOKENIZE_AND_ALERT', severity:'HIGH', category:'geolocation' },
  { id:'RB-011', name:'New device access', condition:(ctx,ml)=>ml.signals?.dev==='new', action:'MASK_FINANCIAL', severity:'LOW', category:'device' },
  { id:'RB-012', name:'Weekend off-hours', condition:(ctx)=>ctx.isWeekend&&ctx.isOffHours, action:'ENHANCED_LOGGING', severity:'LOW', category:'temporal' },
];

function runRuleEngine(context, mlResult, tiResult){
  const triggered = [];
  const notTriggered = [];
  RULES.forEach(rule => {
    try {
      const hit = rule.condition(context, mlResult, tiResult);
      (hit ? triggered : notTriggered).push({...rule, hit});
    } catch(e) { notTriggered.push({...rule, hit:false}); }
  });
  // Determine highest severity action
  const priority = ['BLOCK_AND_ALERT','FULL_REDACT_ALL','ANONYMISE_ALL','TOKENIZE_AND_ALERT','TOKENIZE_PII','ENCRYPT_CRITICAL','MASK_CRITICAL_FIELDS','MASK_FINANCIAL','PSEUDONYMISE_DIRECT_ID','ESCALATE_PROTECTION','ENHANCED_LOGGING','NONE'];
  let topAction = 'NONE';
  triggered.forEach(r => { if(priority.indexOf(r.action) < priority.indexOf(topAction)) topAction = r.action; });
  return { triggered, notTriggered, topAction, triggeredCount: triggered.length };
}

// ═══════════════════════════════════════════════════════
// 4. ML RISK CLASSIFIER (Weighted Logistic Regression)
// ═══════════════════════════════════════════════════════
const W = {
  logins: {0:0, 1:10, 3:24, 5:40},
  loc:    {internal:0, vpn:14, external:28, tor:48},
  time:   {business:0, evening:7, latenight:18, wee:30},
  vel:    {normal:0, high:12, bulk:26, rapid:42},
  dev:    {known:0, new:15, suspicious:30},
  geo:    {none:0, mild:10, extreme:28},
  vol:    {normal:0, large:12, bulk:32},
  external: 50,
};

function sigmoid(x){ return 1/(1+Math.exp(-x)); }

function mlClassify(signals, role, ctxModifier){
  let raw = 0;
  raw += W.logins[signals.logins]||0;
  raw += W.loc[signals.loc]||0;
  raw += W.time[signals.time]||0;
  raw += W.vel[signals.vel]||0;
  raw += W.dev[signals.dev]||0;
  raw += W.geo[signals.geo]||0;
  raw += W.vol[signals.vol]||0;
  if(role === 'third') raw += W.external;
  // Context modifier
  raw = Math.round(raw * (1 + (ctxModifier||0)));

  const score = Math.max(0, Math.min(100, Math.round(sigmoid((raw-45)/18)*100)));
  const level = score<20?'LOW': score<40?'MEDIUM': score<65?'HIGH':'CRITICAL';
  const color = {LOW:'#24D49A', MEDIUM:'#F0A025', HIGH:'#F05050', CRITICAL:'#9B72F0'}[level];

  // Multi-class classification output
  const classLabel = score<20?'NORMAL_ACCESS': score<40?'ELEVATED_RISK': score<65?'SUSPICIOUS_ACTIVITY':'THREAT_DETECTED';
  const confidence = score<20 ? 0.92 : score<40 ? 0.78 : score<65 ? 0.85 : 0.97;

  const features = [
    {name:'Login failures', val:W.logins[signals.logins]||0, max:40},
    {name:'Network',        val:W.loc[signals.loc]||0,       max:48},
    {name:'Access time',    val:W.time[signals.time]||0,     max:30},
    {name:'Txn velocity',   val:W.vel[signals.vel]||0,       max:42},
    {name:'Device trust',   val:W.dev[signals.dev]||0,       max:30},
    {name:'Geo anomaly',    val:W.geo[signals.geo]||0,       max:28},
    {name:'Data volume',    val:W.vol[signals.vol]||0,       max:32},
  ];
  return { score, level, color, features, rawSum:raw, classLabel, confidence, signals };
}

// ═══════════════════════════════════════════════════════
// 5. THREAT INTELLIGENCE MODULE
// ═══════════════════════════════════════════════════════
function runThreatIntelligence(signals, tiInputs, role){
  const ipScores  = {clean:0, watchlist:25, blacklisted:80, datacenter:30};
  const actorScores = {none:0, low:20, high:60};
  const iocScores = {none:0, scraping:35, injection:55, exfil:75};
  const breachScores = {none:0, minor:15, major:45};

  const ipScore     = ipScores[tiInputs.ipRep]||0;
  const actorScore  = actorScores[tiInputs.actor]||0;
  const iocScore    = iocScores[tiInputs.ioc]||0;
  const breachScore = breachScores[tiInputs.breach]||0;

  let total = role==='third' ? 100 : Math.min(100, Math.round((ipScore+actorScore+iocScore+breachScore)/2));
  const tiLevel = total<20?'CLEAN': total<45?'WATCH': total<70?'SUSPICIOUS':'HIGH_THREAT';
  const tiColor = {CLEAN:'#24D49A',WATCH:'#F0A025',SUSPICIOUS:'#F05050',HIGH_THREAT:'#9B72F0'}[tiLevel];

  // IOC feed simulation
  const iocFeed = [];
  if(tiInputs.ipRep !== 'clean') iocFeed.push({type:'IP',value: `${Math.floor(Math.random()*200)+10}.${Math.floor(Math.random()*255)}.x.x`, score: ipScore});
  if(tiInputs.ioc !== 'none')    iocFeed.push({type:'IOC', value: tiInputs.ioc.replace('_',' ').toUpperCase(), score: iocScore});
  if(tiInputs.actor !== 'none')  iocFeed.push({type:'ACTOR', value:'TA-'+Math.floor(Math.random()*9000+1000), score: actorScore});

  return { total, tiLevel, tiColor, ipScore, actorScore, iocScore, breachScore, iocFeed, ipRep:tiInputs.ipRep, actor:tiInputs.actor, ioc:tiInputs.ioc, breach:tiInputs.breach };
}

// ═══════════════════════════════════════════════════════
// 6. METADATA TAGGER
// ═══════════════════════════════════════════════════════
function generateMetadata(record, context, mlResult, ruleResult, tiResult){
  const ts = new Date().toISOString();
  const tags = [];

  // Sensitivity tags
  tags.push({label:'PII:DIRECT', color:'#F05050', bg:'rgba(240,80,80,0.1)', border:'rgba(240,80,80,0.25)'});
  tags.push({label:'FINANCIAL:SENSITIVE', color:'#F0A025', bg:'rgba(240,160,37,0.1)', border:'rgba(240,160,37,0.25)'});
  if(record.aadhaar) tags.push({label:'AADHAAR:REGULATED', color:'#9B72F0', bg:'rgba(155,114,240,0.1)', border:'rgba(155,114,240,0.25)'});
  if(record.pan)     tags.push({label:'TAX:PAN:PROTECTED', color:'#9B72F0', bg:'rgba(155,114,240,0.1)', border:'rgba(155,114,240,0.25)'});

  // Jurisdiction tags
  context.jurisdiction.laws.forEach(law => {
    tags.push({label:law, color:'#24D49A', bg:'rgba(36,212,154,0.08)', border:'rgba(36,212,154,0.2)'});
  });

  // Risk tags
  tags.push({label:`ML:${mlResult.classLabel}`, color:mlResult.color, bg:mlResult.color+'1A', border:mlResult.color+'44'});
  if(ruleResult.triggered.length > 0){
    ruleResult.triggered.slice(0,3).forEach(r => {
      tags.push({label:`RULE:${r.id}`, color:'#F0A025', bg:'rgba(240,160,37,0.08)', border:'rgba(240,160,37,0.2)'});
    });
  }
  if(tiResult.tiLevel !== 'CLEAN'){
    tags.push({label:`THREAT:${tiResult.tiLevel}`, color:tiResult.tiColor, bg:tiResult.tiColor+'1A', border:tiResult.tiColor+'44'});
  }

  // Purpose / channel tags
  tags.push({label:`CH:${context.channel.replace('_','-').toUpperCase()}`, color:'#22C8E8', bg:'rgba(34,200,232,0.08)', border:'rgba(34,200,232,0.2)'});
  tags.push({label:`PURPOSE:${context.purpose.replace('_','-').toUpperCase()}`, color:'#22C8E8', bg:'rgba(34,200,232,0.08)', border:'rgba(34,200,232,0.2)'});
  tags.push({label:`TIME:${context.timeContext.replace('_','-').toUpperCase()}`, color:'#6A7590', bg:'rgba(106,117,144,0.08)', border:'rgba(106,117,144,0.2)'});

  return { tags, dataClassification: mlResult.score<20?'PUBLIC':mlResult.score<40?'INTERNAL':mlResult.score<65?'CONFIDENTIAL':'RESTRICTED', ts, processingId:'PROC-'+Date.now().toString(36).toUpperCase() };
}

