// 19. NOTIFICATION SYSTEM
// ═══════════════════════════════════════════════════════

const NOTIFICATIONS = [];
let _notifFilter = 'all';
let _notifUnread = 0;

/**
 * Push a security alert notification
 * @param {object} opts - { level:'CRITICAL'|'WARNING'|'INFO', title, body, chips[], role, mlScore, ip, action }
 */
function pushNotification(opts){
  const n = {
    id: 'N-' + Date.now().toString(36).toUpperCase(),
    ts: new Date(),
    level: opts.level || 'WARNING',
    title: opts.title || 'Security Event',
    body: opts.body || '',
    chips: opts.chips || [],
    role: opts.role || 'unknown',
    mlScore: opts.mlScore || 0,
    action: opts.action || '—',
    read: false,
  };
  NOTIFICATIONS.unshift(n);
  _notifUnread++;

  // Update badge
  updateNotifBadge();

  // Ring the bell
  const bell = document.getElementById('notif-bell-icon');
  const btn  = document.getElementById('notif-bell-btn');
  bell.classList.remove('bell-ring');
  void bell.offsetWidth; // reflow
  bell.classList.add('bell-ring');
  setTimeout(()=>bell.classList.remove('bell-ring'), 700);

  // Flash header if critical
  if(n.level === 'CRITICAL'){
    const hdr = document.querySelector('.hdr');
    hdr.classList.remove('threat-active');
    void hdr.offsetWidth;
    hdr.classList.add('threat-active');
    setTimeout(()=>hdr.classList.remove('threat-active'), 5000);
  }

  // Update manager alert strip (always, even if manager not logged in yet)
  updateManagerAlertStrip();

  // Show live threat indicator in manager dash
  const liveThreat = document.getElementById('mgr-live-threat');
  if(liveThreat && (n.level === 'CRITICAL' || n.level === 'WARNING')){
    liveThreat.classList.add('visible');
    setTimeout(()=>liveThreat.classList.remove('visible'), 12000);
  }

  // Re-render drawer if open
  if(document.getElementById('notif-drawer').classList.contains('open')){
    renderNotifDrawer();
  }

  // Show a special toast for critical events
  if(n.level === 'CRITICAL'){
    toast(`🚨 ALERT: ${n.title} — check Security Alerts`);
  } else if(n.level === 'WARNING'){
    toast(`⚠ WARNING: ${n.title}`);
  }
}

function updateNotifBadge(){
  const badge = document.getElementById('notif-badge');
  const unread = NOTIFICATIONS.filter(n=>!n.read).length;
  badge.textContent = unread > 9 ? '9+' : String(unread);
  badge.classList.toggle('visible', unread > 0);
  badge.classList.remove('pulse');
  void badge.offsetWidth;
  if(unread > 0) badge.classList.add('pulse');

  // Also update unread count in drawer header
  const uc = document.getElementById('nd-unread-count');
  if(uc){
    if(unread > 0){
      uc.textContent = unread + ' unread';
      uc.style.display = 'inline';
    } else {
      uc.style.display = 'none';
    }
  }
}

function updateManagerAlertStrip(){
  const strip = document.getElementById('mgr-alert-strip');
  if(!strip) return;
  const threats = NOTIFICATIONS.filter(n=>n.level==='CRITICAL'||n.level==='WARNING');
  if(threats.length === 0){ strip.classList.remove('visible'); return; }

  strip.classList.add('visible');
  const latest = threats[0];
  document.getElementById('mas-title').textContent = latest.title;
  document.getElementById('mas-sub').textContent =
    `${threats.length} threat event(s) recorded. Latest: ${latest.role.toUpperCase()} — ML score ${latest.mlScore}/100. PDE protected all sensitive fields.`;
  document.getElementById('mas-count').textContent = threats.length;
}

function renderNotifDrawer(){
  const body = document.getElementById('nd-body');
  const filtered = _notifFilter === 'all'
    ? NOTIFICATIONS
    : NOTIFICATIONS.filter(n => n.level === _notifFilter);

  if(filtered.length === 0){
    body.innerHTML = `<div class="notif-empty"><div class="notif-empty-icon">🔔</div>No alerts in this category.</div>`;
    return;
  }

  const levelClass = {CRITICAL:'nc-critical', WARNING:'nc-warning', INFO:'nc-info'};
  const levelColor = {CRITICAL:'#F05050', WARNING:'#F0A025', INFO:'#4A9AE8'};
  const levelBg    = {CRITICAL:'rgba(194,53,53,0.1)', WARNING:'rgba(196,122,10,0.1)', INFO:'rgba(30,111,194,0.08)'};

  body.innerHTML = filtered.map(n => {
    const ago = formatTimeAgo(n.ts);
    const chips = n.chips.map(c =>
      `<span class="nc-chip" style="background:${c.bg||'rgba(194,53,53,0.08)'};color:${c.c||'#F05050'};border-color:${c.br||'rgba(194,53,53,0.25)'};">${c.label}</span>`
    ).join('');
    return `
      <div class="nc ${levelClass[n.level]||'nc-info'}">
        ${!n.read ? '<div class="nc-unread-dot"></div>' : ''}
        <div class="nc-row1">
          <span class="nc-type" style="background:${levelBg[n.level]};color:${levelColor[n.level]};border:1px solid ${levelColor[n.level]}33;">${n.level}</span>
          <span class="nc-time">${ago}</span>
        </div>
        <div class="nc-title" style="color:${levelColor[n.level]}">${n.title}</div>
        <div class="nc-body">${n.body}</div>
        ${chips ? `<div class="nc-meta">${chips}</div>` : ''}
      </div>
    `;
  }).join('');
}

function formatTimeAgo(date){
  const sec = Math.floor((Date.now() - date.getTime()) / 1000);
  if(sec < 10) return 'just now';
  if(sec < 60) return sec + 's ago';
  if(sec < 3600) return Math.floor(sec/60) + 'm ago';
  return Math.floor(sec/3600) + 'h ago';
}

function toggleNotifDrawer(){
  const drawer  = document.getElementById('notif-drawer');
  const overlay = document.getElementById('notif-overlay');
  const isOpen  = drawer.classList.contains('open');
  if(isOpen){
    closeNotifDrawer();
  } else {
    // Mark all as read when opening
    NOTIFICATIONS.forEach(n => n.read = true);
    updateNotifBadge();
    renderNotifDrawer();
    drawer.classList.add('open');
    overlay.classList.add('open');
  }
}

function closeNotifDrawer(){
  document.getElementById('notif-drawer').classList.remove('open');
  document.getElementById('notif-overlay').classList.remove('open');
}

function filterNotifs(level){
  _notifFilter = level;
  document.querySelectorAll('.nd-filter').forEach(b => {
    b.classList.remove('active','active-all');
  });
  const btn = document.getElementById('nf-'+level.toLowerCase());
  if(btn) btn.classList.add(level === 'all' ? 'active-all' : 'active');
  renderNotifDrawer();
}

function clearAllNotifs(){
  NOTIFICATIONS.length = 0;
  _notifUnread = 0;
  updateNotifBadge();
  updateManagerAlertStrip();
  renderNotifDrawer();
  document.getElementById('mgr-live-threat')?.classList.remove('visible');
}

