// PDE: field-level protection decision matrix
function makeProtectionDecision(field, role, mlResult, ruleResult, tiResult, context){
  const { sensitivity } = field;
  let method = 'visible';
  let reason = 'default_access';

  // Hard overrides from rules
  if(ruleResult.topAction === 'FULL_REDACT_ALL' || ruleResult.topAction === 'BLOCK_AND_ALERT'){
    return { method:'full_redaction', reason:'rule_engine:'+ruleResult.topAction, technique:'redaction' };
  }
  if(ruleResult.topAction === 'ANONYMISE_ALL'){
    return { method:'anonymisation', reason:'rule_engine:ANONYMISE_ALL', technique:'k-anonymity' };
  }

  // Role-based base layer
  if(role === 'third'){
    return { method:'anonymisation', reason:'context:external_role', technique:'k-anonymity+suppression' };
  }

  // ML-score driven decisions per sensitivity
  const score = mlResult.score;
  if(sensitivity === 'critical'){
    if(score < 20)  method = 'visible',        reason = 'ml:LOW+auth';
    else if(score < 40) method = 'visible',    reason = 'ml:MEDIUM+trusted';
    else if(score < 65) method = 'encryption', reason = 'ml:HIGH+encrypt';
    else                method = 'full_redaction', reason = 'ml:CRITICAL+redact';
  } else if(sensitivity === 'sensitive'){
    if(score < 40)  method = 'visible',          reason = 'ml:LOW_MED';
    else if(score < 65) method = 'masking',      reason = 'ml:HIGH+mask';
    else                method = 'encryption',   reason = 'ml:CRITICAL+encrypt';
  } else { // internal
    method = 'visible'; reason = 'internal:always_visible';
  }

  // Threat intelligence override
  if(tiResult.tiLevel === 'HIGH_THREAT' && method === 'visible'){
    method = sensitivity === 'critical' ? 'full_redaction' : 'masking';
    reason = 'threat_intel:HIGH_THREAT';
  }

  // Purpose-based transforms (privacy-preserving)
  if(context.purpose === 'analytics' && sensitivity === 'critical'){
    if(method === 'visible'){
      method = 'pseudonymisation';
      reason = 'purpose:analytics+pseudonymise';
    }
  }
  if(context.purpose === 'third_party'){
    if(field.cat === 'direct_id' || field.cat === 'gov_id'){
      method = 'anonymisation';
      reason = 'purpose:third_party+anonymise';
    }
  }

  // Rule-specific overrides
  if(ruleResult.triggered.some(r=>r.id==='RB-005') && sensitivity==='critical') { method='masking'; reason='rule:RB-005:bulk_mask'; }
  if(ruleResult.triggered.some(r=>r.id==='RB-006') && field.cat==='direct_id')  { method='tokenization'; reason='rule:RB-006:tokenize'; }
  if(ruleResult.triggered.some(r=>r.id==='RB-009') && sensitivity==='critical') { method='encryption'; reason='rule:RB-009:encrypt'; }

  // Pseudonymisation for gov IDs when analytics
  if(field.cat === 'gov_id' && context.purpose === 'analytics'){
    method = 'pseudonymisation';
    reason = 'purpose:analytics+gov_id_pseudo';
  }

  const techniqueMap = {
    visible:'plaintext', masking:'partial_masking', tokenization:'format-preserving-token',
    encryption:'AES-256-GCM', full_redaction:'suppression', anonymisation:'k-anon+generalisation',
    pseudonymisation:'HMAC-SHA256-pseudonym',
  };
  return { method, reason, technique: techniqueMap[method]||'unknown' };
}

function runPDE(role, mlResult, ruleResult, tiResult, context){
  const decisions = {};
  FIELD_DEFS.forEach(f => {
    decisions[f.key] = makeProtectionDecision(f, role, mlResult, ruleResult, tiResult, context);
  });
  return decisions;
}

