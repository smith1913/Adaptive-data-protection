const SENS_COLOR = {critical:'#F05050',sensitive:'#F0A025',internal:'#4A9AE8',public:'#24D49A'};
const MSTYLE = {
  visible:          {lbl:'Visible',      bg:'rgba(13,158,107,0.08)', c:'#24D49A', br:'rgba(13,158,107,0.25)'},
  masking:          {lbl:'Masked',       bg:'rgba(196,122,10,0.08)', c:'#F0A025', br:'rgba(196,122,10,0.25)'},
  tokenization:     {lbl:'Token',        bg:'rgba(30,111,194,0.08)', c:'#4A9AE8', br:'rgba(30,111,194,0.25)'},
  encryption:       {lbl:'AES-256',      bg:'rgba(107,66,200,0.08)', c:'#9B72F0', br:'rgba(107,66,200,0.25)'},
  full_redaction:   {lbl:'Redacted',     bg:'rgba(194,53,53,0.06)', c:'#F05050', br:'rgba(194,53,53,0.2)'},
  anonymisation:    {lbl:'Anonymised',   bg:'rgba(196,122,10,0.06)', c:'#F0A025', br:'rgba(196,122,10,0.2)'},
  pseudonymisation: {lbl:'Pseudonym',    bg:'rgba(10,143,168,0.08)', c:'#22C8E8', br:'rgba(10,143,168,0.25)'},
};

const TOK={}, PSEUDO={};
function h32(s){let h=5381;for(let i=0;i<s.length;i++){h=((h<<5)+h)+s.charCodeAt(i);h|=0;}return Math.abs(h).toString(16).padStart(8,'0').toUpperCase();}

function applyMethod(v, method, fieldKey){
  if(!v||v==='—') return '—';
  const s = String(v);
  switch(method){
    case 'visible':          return s;
    case 'masking':          return '•'.repeat(Math.max(0,s.length-3))+s.slice(-3);
    case 'tokenization':     { const k=h32(s); if(!TOK[k]) TOK[k]='TKN-'+k.slice(0,4)+'-'+k.slice(4,8); return TOK[k]; }
    case 'encryption':       return 'AES256-GCM:'+h32(s+'k9s2').slice(0,8)+'…iv:'+h32(s).slice(0,4);
    case 'full_redaction':   return '[REDACTED]';
    case 'anonymisation':    return '[ANON:k=5:'+h32(s).slice(0,6)+']';
    case 'pseudonymisation': { const k=h32(s+'pepper'+fieldKey); if(!PSEUDO[k]) PSEUDO[k]='PSE-'+k.slice(0,4)+'-'+k.slice(4,8); return PSEUDO[k]; }
    default:                 return '[PROTECTED]';
  }
}

function valClass(method){
  const map = {visible:'fv-plain', masking:'fv-masked', tokenization:'fv-masked', encryption:'fv-enc',
    full_redaction:'fv-red', anonymisation:'fv-anon', pseudonymisation:'fv-pseudo'};
  return map[method]||'fv-plain';
}

function renderFields(cid, record, pdeDecisions){
  const el = document.getElementById(cid);
  el.innerHTML='';
  FIELD_DEFS.forEach(f=>{
    const raw = record[f.key]||'—';
    const dec = pdeDecisions[f.key]||{method:'full_redaction',reason:'no_decision'};
    const pv  = applyMethod(raw, dec.method, f.key);
    const ms  = MSTYLE[dec.method]||MSTYLE.full_redaction;
    const vc  = valClass(dec.method);
    const d = document.createElement('div');
    d.className='frow';
    d.innerHTML=`
      <span class="frow-icon">${f.icon}</span>
      <span class="frow-lbl">${f.label}</span>
      <span class="frow-val ${vc}">${pv}</span>
      <span class="sdot" style="background:${SENS_COLOR[f.sensitivity]}"></span>
      <span class="mtag" style="background:${ms.bg};color:${ms.c};border:1px solid ${ms.br}">${ms.lbl}</span>
    `;
    el.appendChild(d);
  });
}

