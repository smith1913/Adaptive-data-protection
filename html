<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SecureBank — ADPE v7.0 · Intelligent Data Protection Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#03050D;--bg2:#060A15;--bg3:#0A1020;--bg4:#0F1830;--bg5:#162040;
  --gold:#D4A843;--gold2:#F0C96A;--gold3:#8B6A1A;--goldfade:rgba(212,168,67,0.08);
  --blue:#1E6FC2;--blue2:#4A9AE8;--bluefade:rgba(30,111,194,0.08);
  --green:#0D9E6B;--green2:#24D49A;--greenfade:rgba(13,158,107,0.08);
  --red:#C23535;--red2:#F05050;--redfade:rgba(194,53,53,0.08);
  --amber:#C47A0A;--amber2:#F0A025;--amberfade:rgba(196,122,10,0.08);
  --violet:#6B42C8;--violet2:#9B72F0;--violetfade:rgba(107,66,200,0.08);
  --cyan:#0A8FA8;--cyan2:#22C8E8;--cyanfade:rgba(10,143,168,0.08);
  --txt:#E8E2D4;--txt2:#6A7590;--txt3:#3A4460;
  --brd:rgba(212,168,67,0.08);--brd2:rgba(212,168,67,0.18);--brd3:rgba(212,168,67,0.35);
  --serif:'Playfair Display',serif;
  --mono:'JetBrains Mono',monospace;
  --sans:'Space Grotesk',sans-serif;
  --r:14px;--r2:10px;--r3:7px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--txt);font-family:var(--sans);min-height:100vh;overflow-x:hidden;font-size:14px;}

/* Atmosphere */
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 35% at 15% 5%,rgba(212,168,67,0.035) 0%,transparent 65%),
    radial-gradient(ellipse 45% 30% at 85% 95%,rgba(30,111,194,0.03) 0%,transparent 60%),
    radial-gradient(ellipse 30% 20% at 90% 20%,rgba(107,66,200,0.025) 0%,transparent 55%),
    linear-gradient(rgba(212,168,67,0.012) 1px,transparent 1px),
    linear-gradient(90deg,rgba(212,168,67,0.012) 1px,transparent 1px);
  background-size:100% 100%,100% 100%,100% 100%,48px 48px,48px 48px;
}

/* Scrollbar */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg2);}
::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:2px;}

.app{position:relative;z-index:1;max-width:1300px;margin:0 auto;padding:16px;}

/* HEADER */
.hdr{
  display:flex;align-items:center;gap:14px;padding:12px 18px;
  background:rgba(6,10,21,0.85);border:1px solid var(--brd2);border-radius:var(--r);
  margin-bottom:20px;backdrop-filter:blur(12px);
}
.hdr-mark{width:40px;height:40px;border:1.5px solid var(--gold);border-radius:9px;
  display:flex;align-items:center;justify-content:center;font-size:18px;
  background:var(--goldfade);flex-shrink:0;}
.hdr-name{font-family:var(--serif);font-size:21px;color:var(--gold);letter-spacing:.3px;}
.hdr-sub{font-size:8px;color:var(--txt2);font-family:var(--mono);letter-spacing:2px;margin-top:1px;}
.hdr-chips{margin-left:auto;display:flex;align-items:center;gap:7px;flex-wrap:wrap;}
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;
  font-family:var(--mono);font-size:8px;letter-spacing:1px;font-weight:500;}
.chip-gold{background:var(--goldfade);border:1px solid var(--brd2);color:var(--gold);}
.chip-violet{background:var(--violetfade);border:1px solid rgba(107,66,200,0.25);color:var(--violet2);}
.chip-green{background:var(--greenfade);border:1px solid rgba(13,158,107,0.25);color:var(--green2);}
.chip-cyan{background:var(--cyanfade);border:1px solid rgba(10,143,168,0.25);color:var(--cyan2);}
.chip-red{background:var(--redfade);border:1px solid rgba(194,53,53,0.25);color:var(--red2);}
.blink{animation:blink 2.8s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

/* SCREENS */
.screen{display:none;}
.screen.active{display:block;animation:fadeIn .3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* PORTAL */
.portal-hero{text-align:center;padding:32px 0 28px;}
.portal-title{font-family:var(--serif);font-size:42px;color:var(--gold);line-height:1.1;margin-bottom:8px;}
.portal-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 16px;border-radius:20px;
  background:var(--violetfade);border:1px solid rgba(107,66,200,0.2);
  color:var(--violet2);font-family:var(--mono);font-size:9px;letter-spacing:1.5px;margin-bottom:10px;}
.portal-sub{color:var(--txt2);font-size:11px;font-family:var(--mono);letter-spacing:.3px;}

/* Module Banner */
.module-banner{
  display:grid;grid-template-columns:repeat(7,1fr);gap:6px;
  background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);
  padding:12px;margin-bottom:20px;
}
.mb-item{text-align:center;padding:8px 6px;border-radius:var(--r3);background:var(--bg3);border:1px solid var(--brd);cursor:default;transition:border-color .2s;}
.mb-item:hover{border-color:var(--brd2);}
.mb-icon{font-size:18px;margin-bottom:4px;}
.mb-name{font-size:7px;font-family:var(--mono);color:var(--txt2);letter-spacing:.8px;text-transform:uppercase;line-height:1.4;}
.mb-status{font-size:7px;font-family:var(--mono);color:var(--green2);margin-top:2px;}

.portal-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:900px;margin:0 auto;}
.pc{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:26px 18px;
  text-align:center;cursor:pointer;transition:transform .22s,border-color .22s,box-shadow .22s;position:relative;overflow:hidden;}
.pc::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;opacity:0;transition:opacity .22s;}
.pc:hover{transform:translateY(-4px);}
.pc:hover::after{opacity:1;}
.pc-user::after{background:linear-gradient(90deg,transparent,var(--blue2),transparent);}
.pc-mgr::after{background:linear-gradient(90deg,transparent,var(--gold2),transparent);}
.pc-3rd::after{background:linear-gradient(90deg,transparent,var(--red2),transparent);}
.pc:hover.pc-user{border-color:rgba(30,111,194,0.3);box-shadow:0 14px 36px rgba(30,111,194,0.08);}
.pc:hover.pc-mgr{border-color:rgba(212,168,67,0.3);box-shadow:0 14px 36px rgba(212,168,67,0.07);}
.pc:hover.pc-3rd{border-color:rgba(194,53,53,0.3);box-shadow:0 14px 36px rgba(194,53,53,0.06);}
.pc-icon{font-size:40px;display:block;margin-bottom:12px;}
.pc-name{font-family:var(--serif);font-size:20px;margin-bottom:5px;}
.pc-desc{font-size:10px;color:var(--txt2);font-family:var(--mono);line-height:1.7;}
.pc-badge{display:inline-block;margin-top:12px;padding:3px 10px;border-radius:20px;font-size:8px;font-family:var(--mono);letter-spacing:1px;}

/* FORMS */
.form-wrap{max-width:560px;margin:24px auto;}
.form-card{background:var(--bg2);border:1px solid var(--brd2);border-radius:var(--r);padding:28px;position:relative;overflow:hidden;}
.form-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.fc-user::before{background:linear-gradient(90deg,transparent,var(--blue2),transparent);}
.fc-mgr::before{background:linear-gradient(90deg,transparent,var(--gold2),transparent);}
.fc-3rd::before{background:linear-gradient(90deg,transparent,var(--red2),transparent);}
.form-h{font-family:var(--serif);font-size:26px;text-align:center;margin-bottom:4px;}
.form-s{text-align:center;color:var(--txt2);font-size:10px;font-family:var(--mono);margin-bottom:22px;line-height:1.7;}
.fg{margin-bottom:11px;}
.fl{font-size:8px;color:var(--txt2);font-family:var(--mono);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:5px;}
.fi{width:100%;background:var(--bg3);border:1px solid var(--brd);color:var(--txt);
  padding:9px 12px;border-radius:var(--r3);font-family:var(--mono);font-size:11px;outline:none;
  transition:border-color .18s,box-shadow .18s;}
.fi:focus{border-color:var(--gold);box-shadow:0 0 0 3px var(--goldfade);}
.fi::placeholder{color:var(--txt3);}
select.fi{cursor:pointer;}
.fh{font-size:8px;color:var(--txt2);font-family:var(--mono);margin-top:3px;line-height:1.5;}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;}
.ferr{font-size:9px;color:var(--red2);font-family:var(--mono);margin-top:4px;display:none;}

/* Context Section */
.ctx-section{
  background:rgba(10,143,168,0.04);border:1px solid rgba(10,143,168,0.15);
  border-radius:var(--r2);padding:12px;margin:12px 0;
}
.ctx-title{font-size:8px;color:var(--cyan2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;
  display:flex;align-items:center;gap:6px;}
.ctx-title::before{content:'🌐';}

/* ML Section */
.ml-section{
  background:rgba(107,66,200,0.04);border:1px solid rgba(107,66,200,0.15);
  border-radius:var(--r2);padding:12px;margin:12px 0;
}
.ml-sec-title{font-size:8px;color:var(--violet2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;
  display:flex;align-items:center;gap:6px;}
.ml-sec-title::before{content:'⚡';}

/* Threat Intel Section */
.ti-section{
  background:rgba(194,53,53,0.03);border:1px solid rgba(194,53,53,0.12);
  border-radius:var(--r2);padding:12px;margin:12px 0;
}
.ti-title{font-size:8px;color:var(--red2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;
  display:flex;align-items:center;gap:6px;}
.ti-title::before{content:'🛡';}

/* Buttons */
.btn{width:100%;padding:11px;border:none;border-radius:var(--r3);font-family:var(--sans);font-weight:600;font-size:12px;cursor:pointer;transition:all .2s;margin-top:5px;letter-spacing:.3px;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold3));color:#050810;}
.btn-gold:hover{transform:translateY(-1px);box-shadow:0 5px 20px rgba(212,168,67,0.2);}
.btn-blue{background:linear-gradient(135deg,#1E6FC2,#124FA0);color:#fff;}
.btn-blue:hover{transform:translateY(-1px);box-shadow:0 5px 20px rgba(30,111,194,0.2);}
.btn-red{background:var(--redfade);border:1px solid rgba(194,53,53,0.3);color:var(--red2);}
.btn-red:hover{background:rgba(194,53,53,0.12);}
.btn-sm{width:auto;padding:5px 12px;font-size:10px;margin-top:0;}
.back{text-align:center;margin-top:12px;font-size:10px;color:var(--txt2);font-family:var(--mono);cursor:pointer;transition:color .18s;}
.back:hover{color:var(--gold);}

/* Creds box */
.creds-box{background:var(--bg3);border:1px solid var(--brd3);border-radius:var(--r2);padding:14px;margin-bottom:18px;position:relative;overflow:hidden;}
.creds-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.creds-title{font-size:8px;color:var(--gold);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;}
.cred-row{display:flex;align-items:center;padding:8px 10px;background:var(--bg4);border-radius:var(--r3);margin-bottom:5px;gap:8px;border:1px solid var(--brd);}
.cred-k{font-size:8px;color:var(--txt2);font-family:var(--mono);letter-spacing:1px;min-width:80px;}
.cred-v{font-family:var(--mono);font-size:12px;color:var(--gold2);font-weight:500;flex:1;letter-spacing:.8px;}
.copy-btn{font-size:8px;font-family:var(--mono);padding:3px 8px;border-radius:4px;border:1px solid var(--brd2);background:transparent;color:var(--txt2);cursor:pointer;transition:all .15s;flex-shrink:0;}
.copy-btn:hover{border-color:var(--gold);color:var(--gold);}
.creds-warn{font-size:8px;color:var(--txt2);font-family:var(--mono);line-height:1.6;margin-top:7px;padding:7px;background:var(--goldfade);border-radius:5px;}

/* TOPBAR */
.topbar{display:flex;align-items:center;gap:10px;padding:9px 14px;background:rgba(6,10,21,0.7);
  border:1px solid var(--brd);border-radius:var(--r2);margin-bottom:16px;backdrop-filter:blur(8px);}
.tb-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.tb-nm{font-weight:600;font-size:12px;}
.tb-rl{font-size:8px;color:var(--txt2);font-family:var(--mono);margin-top:1px;letter-spacing:.4px;}
.tb-r{margin-left:auto;display:flex;align-items:center;gap:7px;}
.logout-btn{padding:4px 10px;border-radius:5px;font-size:9px;font-family:var(--mono);cursor:pointer;
  transition:all .18s;border:1px solid var(--brd);background:transparent;color:var(--txt2);}
.logout-btn:hover{border-color:var(--red2);color:var(--red2);}

/* DASHBOARD GRID */
.dgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.dgrid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.card{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:18px;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(212,168,67,0.12),transparent);}
.card-h{font-family:var(--mono);font-size:8px;color:var(--txt2);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;
  display:flex;align-items:center;gap:7px;}
.card-h::after{content:'';flex:1;height:1px;background:var(--brd);}

/* TABS */
.tabs{display:flex;gap:4px;margin-bottom:14px;background:var(--bg3);padding:4px;border-radius:var(--r2);border:1px solid var(--brd);}
.tab{flex:1;padding:6px 10px;border-radius:7px;font-family:var(--mono);font-size:9px;letter-spacing:.5px;
  border:none;cursor:pointer;background:transparent;color:var(--txt2);transition:all .18s;text-align:center;}
.tab.active{background:var(--bg4);color:var(--gold);border:1px solid var(--brd2);}
.tab:hover:not(.active){color:var(--txt);}

/* Profile header */
.prof-h{display:flex;align-items:center;gap:10px;padding:11px;background:var(--bg3);border-radius:var(--r2);border:1px solid var(--brd);margin-bottom:10px;}
.prof-av{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;border:2px solid var(--brd2);}
.prof-nm{font-family:var(--serif);font-size:17px;}
.prof-id{font-size:8px;font-family:var(--mono);color:var(--txt2);margin-top:2px;letter-spacing:.4px;}

/* Field rows */
.flist{display:flex;flex-direction:column;gap:3px;}
.frow{display:flex;align-items:center;padding:7px 9px;background:var(--bg3);border:1px solid var(--brd);border-radius:var(--r3);gap:7px;transition:border-color .15s;}
.frow:hover{border-color:var(--brd2);}
.frow-icon{font-size:11px;width:14px;text-align:center;flex-shrink:0;}
.frow-lbl{font-family:var(--mono);font-size:8px;color:var(--txt2);min-width:110px;letter-spacing:.2px;}
.frow-val{flex:1;font-size:10px;font-family:var(--mono);font-weight:500;}
.fv-plain{color:var(--txt);}
.fv-gold{color:var(--gold2);}
.fv-masked{color:var(--txt2);}
.fv-enc{color:var(--violet2);font-size:9px;}
.fv-pseudo{color:var(--cyan2);font-size:9px;}
.fv-anon{color:var(--amber2);font-size:9px;}
.fv-red{color:rgba(194,53,53,0.5);font-size:9px;}
.sdot{width:4px;height:4px;border-radius:50%;flex-shrink:0;}
.mtag{font-size:7px;font-family:var(--mono);padding:2px 5px;border-radius:3px;text-transform:uppercase;letter-spacing:.4px;flex-shrink:0;font-weight:500;}

/* ML PANEL */
.ml-panel{background:linear-gradient(135deg,rgba(107,66,200,0.05),rgba(30,111,194,0.03));
  border:1px solid rgba(107,66,200,0.18);border-radius:var(--r2);padding:13px;margin-bottom:12px;}
.ml-panel-h{font-size:8px;color:var(--violet2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;
  display:flex;align-items:center;justify-content:space-between;}
.ml-score-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
.ml-score-big{font-family:var(--serif);font-size:44px;line-height:1;}
.ml-features-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:9px;}
.ml-feat{background:var(--bg4);border-radius:6px;padding:7px 9px;border:1px solid var(--brd);}
.mf-name{font-size:7px;color:var(--txt2);font-family:var(--mono);letter-spacing:.6px;margin-bottom:3px;}
.mf-score{font-family:var(--mono);font-size:11px;font-weight:600;margin-bottom:2px;}
.mf-bar{height:2px;border-radius:1px;background:var(--bg5);overflow:hidden;}
.mf-fill{height:100%;border-radius:1px;transition:width 1.2s cubic-bezier(.4,0,.2,1);}
.ml-total-bar{height:5px;border-radius:3px;background:var(--bg5);overflow:hidden;margin-top:7px;}
.ml-total-fill{height:100%;border-radius:3px;transition:width 1.2s cubic-bezier(.4,0,.2,1);}
.ml-badge{padding:4px 10px;border-radius:5px;font-family:var(--mono);font-size:9px;font-weight:600;}

/* RULE ENGINE PANEL */
.rule-panel{background:rgba(212,168,67,0.03);border:1px solid var(--brd2);border-radius:var(--r2);padding:12px;margin-bottom:12px;}
.rule-h{font-size:8px;color:var(--gold);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;}
.rule-row{display:flex;align-items:center;padding:6px 8px;background:var(--bg3);border:1px solid var(--brd);border-radius:5px;margin-bottom:4px;gap:8px;font-family:var(--mono);font-size:9px;}
.rule-id{color:var(--gold2);min-width:60px;font-weight:600;}
.rule-cond{color:var(--txt2);flex:1;}
.rule-result{font-size:8px;padding:2px 6px;border-radius:3px;}

/* THREAT INTEL PANEL */
.ti-panel{background:rgba(194,53,53,0.03);border:1px solid rgba(194,53,53,0.15);border-radius:var(--r2);padding:12px;margin-bottom:12px;}
.ti-h{font-size:8px;color:var(--red2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;display:flex;justify-content:space-between;}
.ti-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(194,53,53,0.05);font-family:var(--mono);font-size:9px;}
.ti-row:last-child{border:none;}
.ti-icon{font-size:11px;width:16px;}
.ti-lbl{color:var(--txt2);flex:1;}
.ti-val{font-weight:600;}
.ti-safe{color:var(--green2);}
.ti-warn{color:var(--amber2);}
.ti-danger{color:var(--red2);}

/* METADATA TAGS */
.meta-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;}
.meta-tag{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:3px;font-family:var(--mono);font-size:7px;letter-spacing:.5px;font-weight:500;}

/* PROTECTION DECISION */
.pde-panel{background:linear-gradient(135deg,rgba(13,158,107,0.04),rgba(0,0,0,0));
  border:1px solid rgba(13,158,107,0.15);border-radius:var(--r2);padding:12px;margin-bottom:12px;}
.pde-h{font-size:8px;color:var(--green2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;}
.pde-row{display:flex;align-items:center;padding:6px 8px;background:var(--bg3);border:1px solid var(--brd);border-radius:5px;margin-bottom:4px;gap:8px;font-family:var(--mono);font-size:9px;}
.pde-field{color:var(--txt2);min-width:100px;}
.pde-class{min-width:60px;}
.pde-method{flex:1;}
.pde-reason{color:var(--txt2);font-size:8px;}

/* LOCK STATUS */
.lock-panel{border-radius:var(--r2);padding:12px;border:1px solid;margin-top:10px;}
.lock-h{font-size:8px;font-family:var(--mono);letter-spacing:2px;margin-bottom:9px;display:flex;align-items:center;gap:6px;}
.lock-row{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.03);font-family:var(--mono);font-size:9px;}
.lock-row:last-child{border:none;}

/* Context Panel */
.ctx-panel{background:rgba(10,143,168,0.03);border:1px solid rgba(10,143,168,0.15);border-radius:var(--r2);padding:12px;margin-bottom:12px;}
.ctx-h{font-size:8px;color:var(--cyan2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;}
.ctx-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(10,143,168,0.04);font-family:var(--mono);font-size:9px;}
.ctx-row:last-child{border:none;}
.ctx-icon{font-size:11px;width:16px;}
.ctx-lbl{color:var(--txt2);min-width:110px;}
.ctx-val{color:var(--cyan2);font-weight:500;}

/* Audit */
.ae{padding:9px 11px;background:var(--bg3);border:1px solid var(--brd);border-left:3px solid var(--gold3);
  border-radius:6px;margin-bottom:5px;font-family:var(--mono);font-size:8px;line-height:2;animation:fadeIn .3s ease;}
.ak{color:var(--txt2);}
.av{color:var(--txt);}
.aid{color:var(--gold);font-size:7px;}

/* Compliance */
.comp-row{display:flex;gap:5px;flex-wrap:wrap;}
.ct{padding:3px 9px;border-radius:4px;background:var(--greenfade);border:1px solid rgba(13,158,107,0.2);
  color:var(--green2);font-family:var(--mono);font-size:8px;font-weight:500;}

/* Records table */
.rec-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:9px;}
.rec-table th{text-align:left;padding:6px 9px;color:var(--txt2);border-bottom:1px solid var(--brd);font-size:7px;letter-spacing:1.5px;text-transform:uppercase;}
.rec-table td{padding:7px 9px;border-bottom:1px solid rgba(212,168,67,0.03);color:var(--txt);}
.rec-table tbody tr{cursor:pointer;transition:background .12s;}
.rec-table tbody tr:hover td{background:var(--goldfade);}
.rec-table tbody tr.selected td{background:rgba(212,168,67,0.05);}
.risk-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:9px;font-size:7px;font-weight:600;font-family:var(--mono);}

/* Denied */
.denied{padding:13px 18px;background:var(--redfade);border:1px solid rgba(194,53,53,0.25);border-radius:var(--r2);margin-bottom:16px;}
.denied-t{font-size:12px;font-weight:700;color:var(--red2);margin-bottom:2px;}
.denied-s{font-size:9px;color:rgba(194,53,53,0.6);font-family:var(--mono);line-height:1.6;}

/* Success */
.sbanner{padding:10px 14px;background:var(--greenfade);border:1px solid rgba(13,158,107,0.2);border-radius:var(--r3);margin-bottom:12px;font-family:var(--mono);font-size:9px;color:var(--green2);line-height:1.6;}

/* Stats grid */
.s3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px;}
.sbox{padding:10px;text-align:center;background:var(--bg3);border:1px solid var(--brd);border-radius:var(--r3);}
.sn{font-family:var(--serif);font-size:20px;}
.sl{font-size:7px;color:var(--txt2);font-family:var(--mono);letter-spacing:1px;margin-top:2px;}

/* Threat bars */
.threat-big{font-family:var(--serif);font-size:42px;line-height:1;}
.tbar{height:4px;border-radius:2px;background:var(--bg5);overflow:hidden;margin-top:6px;}
.tfill{height:100%;border-radius:2px;transition:width .9s cubic-bezier(.4,0,.2,1);}
.irow{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:9px;padding:5px 0;border-bottom:1px solid var(--brd);}
.irow:last-child{border:none;}
.irow::before{content:'⚠';font-size:9px;}

/* HACK TERMINAL */
#hack-overlay{position:fixed;inset:0;z-index:500;background:#000;display:none;flex-direction:column;
  align-items:center;justify-content:center;font-family:var(--mono);}
.hack-box{width:100%;max-width:720px;padding:28px;}
.hack-h{font-size:13px;color:#DC2626;margin-bottom:18px;letter-spacing:2px;}
.hline{font-size:10px;line-height:2.1;}
.hc{color:#16A34A;}.hd{color:#1C1C1C;}.hr{color:#0A0A0A;background:#070707;padding:1px 5px;border-radius:2px;}.he{color:#DC2626;}
.hcl{margin-top:22px;padding:7px 20px;border:1px solid #1A1A1A;border-radius:6px;background:transparent;
  color:#333;font-family:var(--mono);font-size:9px;cursor:pointer;transition:all .18s;}
.hcl:hover{border-color:#DC2626;color:#DC2626;}

/* Toast */
.toast{position:fixed;bottom:18px;right:18px;z-index:600;padding:9px 14px;background:var(--bg2);
  border:1px solid var(--brd2);border-radius:9px;font-family:var(--mono);font-size:9px;color:var(--gold);
  transform:translateY(40px);opacity:0;transition:all .25s cubic-bezier(.4,0,.2,1);pointer-events:none;}
.toast.show{transform:translateY(0);opacity:1;}

/* Context awareness indicator */
.ctx-indicator{display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:5px;
  font-family:var(--mono);font-size:8px;font-weight:500;}

/* Pipeline visualization */
.pipeline{display:flex;align-items:center;gap:4px;margin:10px 0;overflow-x:auto;padding:2px;}
.pipe-step{display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0;min-width:70px;}
.pipe-box{padding:6px 8px;border-radius:5px;font-family:var(--mono);font-size:7px;letter-spacing:.5px;
  text-align:center;border:1px solid;font-weight:600;}
.pipe-arrow{color:var(--txt3);font-size:10px;flex-shrink:0;}
.pipe-label{font-size:6px;color:var(--txt3);font-family:var(--mono);letter-spacing:.5px;}

/* Real-world problem badge */
.rwp-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 8px;border-radius:4px;
  font-family:var(--mono);font-size:7px;letter-spacing:.5px;background:rgba(196,122,10,0.08);
  border:1px solid rgba(196,122,10,0.2);color:var(--amber2);}

/* Tab content */
.tab-content{display:none;}
.tab-content.active{display:block;}

/* Unknown Person chip */
.chip-amber{background:var(--amberfade);border:1px solid rgba(196,122,10,0.25);color:var(--amber2);}

/* Unknown Person portal card */
.pc-unk::after{background:linear-gradient(90deg,transparent,var(--amber2),transparent);}
.pc:hover.pc-unk{border-color:rgba(196,122,10,0.3);box-shadow:0 14px 36px rgba(196,122,10,0.07);}

/* UNKNOWN VIEW styles */
.unk-warning{padding:13px 18px;background:var(--amberfade);border:1px solid rgba(196,122,10,0.3);border-radius:var(--r2);margin-bottom:16px;}
.unk-warning-t{font-size:12px;font-weight:700;color:var(--amber2);margin-bottom:2px;}
.unk-warning-s{font-size:9px;color:rgba(196,122,10,0.6);font-family:var(--mono);line-height:1.6;}

/* Glassmask blur overlay on field rows */
.frow-blur{position:relative;overflow:hidden;}
.frow-blur .frow-val::after{
  content:'';position:absolute;inset:0;backdrop-filter:blur(5px);
  background:rgba(3,5,13,0.45);border-radius:3px;pointer-events:none;
}
.frow-blur .frow-val{position:relative;filter:blur(4px);user-select:none;}
.frow-blur .frow-lbl{color:rgba(196,122,10,0.4)!important;}

/* Lock icon overlay on field rows */
.frow-lock{position:relative;}
.frow-lock::after{
  content:'🔒';position:absolute;right:8px;top:50%;transform:translateY(-50%);
  font-size:9px;opacity:.5;pointer-events:none;
}

/* Identity blur card */
.unk-id-block{
  padding:18px;background:rgba(196,122,10,0.04);border:1px solid rgba(196,122,10,0.18);
  border-radius:var(--r2);margin-bottom:14px;text-align:center;
}
.unk-id-avatar{font-size:42px;margin-bottom:8px;filter:grayscale(1);opacity:.4;}
.unk-id-name{font-family:var(--serif);font-size:22px;color:rgba(196,122,10,0.3);
  filter:blur(6px);user-select:none;margin-bottom:4px;}
.unk-id-sub{font-size:9px;font-family:var(--mono);color:rgba(196,122,10,0.3);}

/* Upgrade banner */
.upgrade-banner{
  padding:16px 20px;background:linear-gradient(135deg,rgba(196,122,10,0.07),rgba(212,168,67,0.04));
  border:1px solid rgba(196,122,10,0.25);border-radius:var(--r2);margin-bottom:16px;
  display:flex;align-items:center;gap:14px;
}
.upgrade-icon{font-size:28px;flex-shrink:0;}
.upgrade-text{flex:1;}
.upgrade-title{font-family:var(--serif);font-size:16px;color:var(--amber2);margin-bottom:3px;}
.upgrade-sub{font-size:9px;font-family:var(--mono);color:rgba(196,122,10,0.55);line-height:1.6;}
.upgrade-btns{display:flex;gap:7px;flex-shrink:0;}
.btn-amber{background:linear-gradient(135deg,var(--amber),#8B5A00);color:#fff;border:none;}
.btn-amber:hover{transform:translateY(-1px);box-shadow:0 5px 20px rgba(196,122,10,0.25);}

/* Partial reveal: show first char, blur rest */
.partial-reveal{letter-spacing:2px;}

/* Access score bar for unknown */
.access-score-panel{
  background:rgba(196,122,10,0.04);border:1px solid rgba(196,122,10,0.18);
  border-radius:var(--r2);padding:14px;margin-bottom:12px;
}
.access-score-h{font-size:8px;color:var(--amber2);font-family:var(--mono);letter-spacing:2px;margin-bottom:10px;}
.access-item{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(196,122,10,0.05);font-family:var(--mono);font-size:9px;}
.access-item:last-child{border:none;}
.access-icon{font-size:11px;width:16px;}
.access-lbl{color:var(--txt2);flex:1;}
.access-val{color:var(--amber2);font-weight:600;}
.access-denied{color:rgba(196,122,10,0.4);}

/* ═══════════════════════════════════════════════
   NOTIFICATION SYSTEM
═══════════════════════════════════════════════ */

/* Bell button in header */
.notif-btn{
  position:relative;display:flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:9px;border:1px solid var(--brd2);
  background:var(--bg3);cursor:pointer;transition:all .18s;flex-shrink:0;font-size:15px;
}
.notif-btn:hover{border-color:var(--gold);background:var(--goldfade);}
.notif-badge{
  position:absolute;top:-5px;right:-5px;min-width:16px;height:16px;
  border-radius:8px;background:var(--red2);color:#fff;font-family:var(--mono);
  font-size:8px;font-weight:700;display:flex;align-items:center;justify-content:center;
  padding:0 4px;border:2px solid var(--bg);opacity:0;transition:opacity .2s;
}
.notif-badge.visible{opacity:1;}
.notif-badge.pulse{animation:notifPulse 1s ease-out;}
@keyframes notifPulse{0%{transform:scale(1)}30%{transform:scale(1.5)}100%{transform:scale(1)}}

/* Bell ring animation */
.bell-ring{animation:bellRing .6s ease-out;}
@keyframes bellRing{0%{transform:rotate(0)}20%{transform:rotate(-20deg)}40%{transform:rotate(20deg)}60%{transform:rotate(-15deg)}80%{transform:rotate(10deg)}100%{transform:rotate(0)}}

/* Notification drawer overlay */
#notif-overlay{
  position:fixed;inset:0;z-index:450;pointer-events:none;
  background:rgba(3,5,13,0);transition:background .28s;
}
#notif-overlay.open{pointer-events:all;background:rgba(3,5,13,0.55);}

/* Notification drawer panel */
#notif-drawer{
  position:fixed;top:0;right:0;bottom:0;width:380px;z-index:451;
  background:var(--bg2);border-left:1px solid var(--brd2);
  transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;overflow:hidden;
}
#notif-drawer.open{transform:translateX(0);}

.nd-header{
  padding:16px 18px;border-bottom:1px solid var(--brd);
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(6,10,21,0.9);backdrop-filter:blur(12px);flex-shrink:0;
}
.nd-title{font-family:var(--serif);font-size:18px;color:var(--gold);}
.nd-sub{font-size:7px;font-family:var(--mono);color:var(--txt2);letter-spacing:1.5px;margin-top:2px;}
.nd-close{width:28px;height:28px;border-radius:6px;border:1px solid var(--brd);background:transparent;
  color:var(--txt2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;
  transition:all .15s;}
.nd-close:hover{border-color:var(--red2);color:var(--red2);}

.nd-filters{
  display:flex;gap:5px;padding:10px 18px;border-bottom:1px solid var(--brd);flex-shrink:0;
}
.nd-filter{
  padding:3px 9px;border-radius:12px;font-family:var(--mono);font-size:7px;letter-spacing:.8px;
  border:1px solid var(--brd);background:transparent;color:var(--txt2);cursor:pointer;transition:all .15s;
}
.nd-filter.active{background:var(--redfade);border-color:rgba(194,53,53,0.3);color:var(--red2);}
.nd-filter.active-all{background:var(--goldfade);border-color:var(--brd2);color:var(--gold);}

.nd-body{flex:1;overflow-y:auto;padding:10px;}

.notif-empty{
  text-align:center;padding:40px 20px;font-family:var(--mono);
  font-size:9px;color:var(--txt3);line-height:2;
}
.notif-empty-icon{font-size:32px;margin-bottom:10px;opacity:.3;}

/* Notification card */
.nc{
  padding:12px 14px;border-radius:var(--r3);margin-bottom:7px;
  border:1px solid;position:relative;overflow:hidden;animation:ncSlide .3s ease-out;
  cursor:default;transition:border-color .15s;
}
@keyframes ncSlide{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
.nc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}

.nc-critical{background:rgba(194,53,53,0.06);border-color:rgba(194,53,53,0.2);}
.nc-critical::before{background:var(--red2);}
.nc-critical:hover{border-color:rgba(194,53,53,0.4);}

.nc-warning{background:rgba(196,122,10,0.06);border-color:rgba(196,122,10,0.2);}
.nc-warning::before{background:var(--amber2);}
.nc-warning:hover{border-color:rgba(196,122,10,0.4);}

.nc-info{background:rgba(30,111,194,0.05);border-color:rgba(30,111,194,0.18);}
.nc-info::before{background:var(--blue2);}

.nc-row1{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.nc-type{font-family:var(--mono);font-size:7px;letter-spacing:1.5px;font-weight:700;
  padding:2px 6px;border-radius:3px;}
.nc-time{font-family:var(--mono);font-size:7px;color:var(--txt3);}
.nc-title{font-family:var(--sans);font-size:11px;font-weight:600;margin-bottom:3px;line-height:1.3;}
.nc-body{font-family:var(--mono);font-size:8px;color:var(--txt2);line-height:1.7;}
.nc-meta{display:flex;flex-wrap:wrap;gap:3px;margin-top:6px;}
.nc-chip{font-family:var(--mono);font-size:7px;padding:1px 5px;border-radius:3px;border:1px solid;}
.nc-unread-dot{
  position:absolute;top:10px;right:10px;width:5px;height:5px;
  border-radius:50%;background:var(--red2);
}

/* Manager dashboard alert strip */
.mgr-alert-strip{
  display:none;padding:10px 14px;
  background:linear-gradient(135deg,rgba(194,53,53,0.06),rgba(196,122,10,0.04));
  border:1px solid rgba(194,53,53,0.22);border-radius:var(--r2);margin-bottom:12px;
}
.mgr-alert-strip.visible{display:flex;align-items:center;gap:10px;animation:fadeIn .3s ease;}
.mas-icon{font-size:18px;flex-shrink:0;animation:bellRing 1s ease-out;}
.mas-text{flex:1;}
.mas-title{font-size:11px;font-weight:700;color:var(--red2);margin-bottom:2px;}
.mas-sub{font-size:8px;font-family:var(--mono);color:rgba(194,53,53,0.55);line-height:1.6;}
.mas-count{
  font-family:var(--serif);font-size:28px;color:var(--red2);flex-shrink:0;line-height:1;
}

/* Live threat indicator in manager topbar */
.live-threat-indicator{
  display:none;align-items:center;gap:5px;padding:4px 10px;border-radius:12px;
  background:rgba(194,53,53,0.1);border:1px solid rgba(194,53,53,0.25);
  font-family:var(--mono);font-size:8px;color:var(--red2);animation:threatPulse 2s infinite;
}
.live-threat-indicator.visible{display:flex;}
@keyframes threatPulse{0%,100%{box-shadow:0 0 0 0 rgba(194,53,53,0)}50%{box-shadow:0 0 0 4px rgba(194,53,53,0.1)}}

/* Notification page header flash */
@keyframes headerFlash{0%,100%{border-color:var(--brd2)}50%{border-color:rgba(194,53,53,0.5)}}
.hdr.threat-active{animation:headerFlash 1.5s ease 3;}

@media(max-width:750px){
  #notif-drawer{width:100%;}
}
</style>
</head>
<body>
